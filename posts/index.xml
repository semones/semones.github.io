</span></span><span class="line"><span class="cl">    <span class="nt">&#34;code-runner.executorMap&#34;</span><span class="p">:</span> <span class="p">{</span>                        <span class="c1">// 编程语言对应的执行命令
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>        <span class="nt">&#34;javascript&#34;</span><span class="p">:</span> <span class="s2">&#34;node&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">        <span class="nt">&#34;php&#34;</span><span class="p">:</span> <span class="s2">&#34;C:\\php\\php.exe&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">        <span class="nt">&#34;python&#34;</span><span class="p">:</span> <span class="s2">&#34;python&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">        <span class="nt">&#34;perl&#34;</span><span class="p">:</span> <span class="s2">&#34;perl&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">        <span class="nt">&#34;ruby&#34;</span><span class="p">:</span> <span class="s2">&#34;C:\\Ruby23-x64\\bin\\ruby.exe&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">        <span class="nt">&#34;go&#34;</span><span class="p">:</span> <span class="s2">&#34;go run&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">        <span class="nt">&#34;html&#34;</span><span class="p">:</span> <span class="s2">&#34;\&#34;C:\\Program Files (x86)\\Google\\Chrome\\Application\\chrome.exe\&#34;&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">        <span class="nt">&#34;java&#34;</span><span class="p">:</span> <span class="s2">&#34;cd $dir &amp;&amp; javac $fileName &amp;&amp; java $fileNameWithoutExt&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">        <span class="c1">// 控制台代码页切换到 UTF-8 (65001)，避免中文乱码
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>        <span class="nt">&#34;c&#34;</span><span class="p">:</span> <span class="s2">&#34;chcp 65001 &amp;&amp; cd $dir &amp;&amp; gcc $fileName -o $fileNameWithoutExt &amp;&amp; $dir$fileNameWithoutExt&#34;</span>
</span></span><span class="line"><span class="cl">    <span class="p">},</span>
</span></span><span class="line"><span class="cl">
</span></span><span class="line"><span class="cl">
</span></span><span class="line"><span class="cl">    <span class="c1">// Lingma - Alibaba Cloud AI Coding Assistant
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;Lingma.aI Chat.memories&#34;</span><span class="p">:</span> <span class="kc">false</span><span class="p">,</span>                           <span class="c1">// 关闭通义灵码记忆功能
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;Lingma.aI Chat.webToolsInAsk/AgentMode&#34;</span><span class="p">:</span> <span class="s2">&#34;Auto-execute&#34;</span><span class="p">,</span>   <span class="c1">// 允许通义灵码自动调用工具
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>
</span></span><span class="line"><span class="cl">
</span></span><span class="line"><span class="cl">    <span class="c1">// Python
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;python.autoComplete.extraPaths&#34;</span><span class="p">:</span> <span class="p">[],</span>               <span class="c1">// 为自动补全功能添加额外的模块搜索路径
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;python.analysis.completeFunctionParens&#34;</span><span class="p">:</span> <span class="kc">true</span><span class="p">,</span>     <span class="c1">// 开启自动补全括号和占位符
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;python.analysis.typeCheckingMode&#34;</span><span class="p">:</span> <span class="s2">&#34;standard&#34;</span><span class="p">,</span>     <span class="c1">// 设置类型检查模式为标准
</span></span></span><span class="line"><span class="cl"><span class="c1"></span><span class="p">}</span>
</span></span></code></pre></div>]]></description>
</item>
