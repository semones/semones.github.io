</table>
<h2 id="-插件配置">🔧 插件配置</h2>
<h3 id="1-code-runner">1. Code Runner</h3>
<div class="highlight"><pre tabindex="0" class="chroma"><code class="language-json" data-lang="json"><span class="line"><span class="cl"><span class="c1">// Code Runner
</span></span></span><span class="line"><span class="cl"><span class="c1"></span><span class="s2">&#34;code-runner.runInTerminal&#34;</span><span class="err">:</span> <span class="kc">true</span><span class="err">,</span>					<span class="c1">// 在 VS Code 集成的终端中运行
</span></span></span><span class="line"><span class="cl"><span class="c1"></span><span class="s2">&#34;code-runner.languageIdToFileExtensionMap&#34;</span><span class="err">:</span> <span class="p">{</span>		<span class="c1">// 扩展名映射
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;bat&#34;</span><span class="p">:</span> <span class="s2">&#34;.bat&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">    <span class="nt">&#34;powershell&#34;</span><span class="p">:</span> <span class="s2">&#34;.ps1&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">    <span class="nt">&#34;typescript&#34;</span><span class="p">:</span> <span class="s2">&#34;.ts&#34;</span>
</span></span><span class="line"><span class="cl"><span class="p">}</span><span class="err">,</span>
</span></span><span class="line"><span class="cl"><span class="s2">&#34;code-runner.executorMap&#34;</span><span class="err">:</span> <span class="p">{</span>						<span class="c1">// 编程语言对应的执行命令
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;javascript&#34;</span><span class="p">:</span> <span class="s2">&#34;node&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">    <span class="nt">&#34;php&#34;</span><span class="p">:</span> <span class="s2">&#34;C:\\php\\php.exe&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">    <span class="nt">&#34;python&#34;</span><span class="p">:</span> <span class="s2">&#34;python&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">    <span class="nt">&#34;perl&#34;</span><span class="p">:</span> <span class="s2">&#34;perl&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">    <span class="nt">&#34;ruby&#34;</span><span class="p">:</span> <span class="s2">&#34;C:\\Ruby23-x64\\bin\\ruby.exe&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">    <span class="nt">&#34;go&#34;</span><span class="p">:</span> <span class="s2">&#34;go run&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">    <span class="nt">&#34;html&#34;</span><span class="p">:</span> <span class="s2">&#34;\&#34;C:\\Program Files (x86)\\Google\\Chrome\\Application\\chrome.exe\&#34;&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">    <span class="nt">&#34;java&#34;</span><span class="p">:</span> <span class="s2">&#34;cd $dir &amp;&amp; javac $fileName &amp;&amp; java $fileNameWithoutExt&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">    <span class="c1">// 控制台代码页切换到 UTF-8 (65001)，避免中文乱码
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;c&#34;</span><span class="p">:</span> <span class="s2">&#34;chcp 65001 &amp;&amp; cd $dir &amp;&amp; gcc $fileName -o $fileNameWithoutExt &amp;&amp; $dir$fileNameWithoutExt&#34;</span>
</span></span><span class="line"><span class="cl"><span class="p">}</span><span class="err">,</span>
</span></span></code></pre></div><h3 id="2-lingma---alibaba-cloud-ai-coding-assistant">2. Lingma - Alibaba Cloud AI Coding Assistant</h3>
<div class="highlight"><pre tabindex="0" class="chroma"><code class="language-json" data-lang="json"><span class="line"><span class="cl"><span class="c1">// Lingma - Alibaba Cloud AI Coding Assistant
</span></span></span><span class="line"><span class="cl"><span class="c1"></span><span class="s2">&#34;Lingma.aI Chat.memories&#34;</span><span class="err">:</span> <span class="kc">false</span><span class="err">,</span>							<span class="c1">// 关闭通义灵码记忆功能
</span></span></span><span class="line"><span class="cl"><span class="c1"></span><span class="s2">&#34;Lingma.aI Chat.webToolsInAsk/AgentMode&#34;</span><span class="err">:</span> <span class="s2">&#34;Auto-execute&#34;</span><span class="err">,</span>	<span class="c1">// 允许通义灵码自动调用工具
</span></span></span></code></pre></div><h3 id="3-python">3. Python</h3>
<div class="highlight"><pre tabindex="0" class="chroma"><code class="language-json" data-lang="json"><span class="line"><span class="cl"><span class="c1">// Python
</span></span></span><span class="line"><span class="cl"><span class="c1"></span><span class="s2">&#34;python.autoComplete.extraPaths&#34;</span><span class="err">:</span> <span class="p">[]</span><span class="err">,</span>				<span class="c1">// 为自动补全功能添加额外的模块搜索路径
</span></span></span><span class="line"><span class="cl"><span class="c1"></span><span class="s2">&#34;python.analysis.completeFunctionParens&#34;</span><span class="err">:</span> <span class="kc">true</span><span class="err">,</span>		<span class="c1">// 开启自动补全括号和占位符
</span></span></span><span class="line"><span class="cl"><span class="c1"></span><span class="s2">&#34;python.analysis.typeCheckingMode&#34;</span><span class="err">:</span> <span class="s2">&#34;standard&#34;</span><span class="err">,</span>		<span class="c1">// 设置类型检查模式为标准
</span></span></span></code></pre></div><h2 id="-配置文件">📄 配置文件</h2>
<div class="highlight"><pre tabindex="0" class="chroma"><code class="language-json" data-lang="json"><span class="line"><span class="cl"><span class="p">{</span>
</span></span><span class="line"><span class="cl">    <span class="c1">// 程序设置
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;update.enableWindowsBackgroundUpdates&#34;</span><span class="p">:</span> <span class="kc">false</span><span class="p">,</span> <span class="c1">// 禁止后台下载更新
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;update.mode&#34;</span><span class="p">:</span> <span class="s2">&#34;none&#34;</span><span class="p">,</span>                          <span class="c1">// 禁止任何更新行为
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;extensions.autoCheckUpdates&#34;</span><span class="p">:</span> <span class="kc">false</span><span class="p">,</span>           <span class="c1">// 禁止插件检查更新
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;extensions.autoUpdate&#34;</span><span class="p">:</span> <span class="kc">false</span><span class="p">,</span>                 <span class="c1">// 禁止插件自动更新
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;extensions.ignoreRecommendations&#34;</span><span class="p">:</span> <span class="kc">true</span><span class="p">,</span>       <span class="c1">// 关闭插件安装建议
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;files.autoGuessEncoding&#34;</span><span class="p">:</span> <span class="kc">true</span><span class="p">,</span>                <span class="c1">// 打开文件时猜测字符集编码
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;explorer.compactFolders&#34;</span><span class="p">:</span> <span class="kc">false</span><span class="p">,</span>               <span class="c1">// 关闭文件夹紧凑显示模式
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;chat.agentsControl.enabled&#34;</span><span class="p">:</span> <span class="s2">&#34;hidden&#34;</span><span class="p">,</span>         <span class="c1">// 关闭 Copilot 代理控制功能
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>
</span></span><span class="line"><span class="cl">
</span></span><span class="line"><span class="cl">    <span class="c1">// 工作区设置
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;workbench.startupEditor&#34;</span><span class="p">:</span> <span class="s2">&#34;none&#34;</span><span class="p">,</span>              <span class="c1">// 关闭启动页面
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;workbench.editor.empty.hint&#34;</span><span class="p">:</span> <span class="s2">&#34;hidden&#34;</span><span class="p">,</span>        <span class="c1">// 编辑器为空时，不提示打开文件
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;workbench.list.smoothScrolling&#34;</span><span class="p">:</span> <span class="kc">true</span><span class="p">,</span>         <span class="c1">// 开启界面平滑滚动效果
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;workbench.colorTheme&#34;</span><span class="p">:</span> <span class="s2">&#34;Dracula Theme Soft&#34;</span><span class="p">,</span>   <span class="c1">// 用 Dracula Theme Official 插件设置主题外观
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;workbench.iconTheme&#34;</span><span class="p">:</span> <span class="s2">&#34;material-icon-theme&#34;</span><span class="p">,</span>   <span class="c1">// 用 Material Icon Theme 插件设置图标样式
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>
</span></span><span class="line"><span class="cl">
</span></span><span class="line"><span class="cl">    <span class="c1">// 编辑器设置
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;editor.fontSize&#34;</span><span class="p">:</span> <span class="mi">18</span><span class="p">,</span>                          <span class="c1">// 字体大小
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;editor.mouseWheelZoom&#34;</span><span class="p">:</span> <span class="kc">true</span><span class="p">,</span>                  <span class="c1">// 允许使用 ctrl + 滚轮缩放字体大小
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;editor.fontFamily&#34;</span><span class="p">:</span> <span class="s2">&#34;Consolas, &#39;微软雅黑&#39;&#34;</span><span class="p">,</span>     <span class="c1">// 设置字体
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;editor.smoothScrolling&#34;</span><span class="p">:</span> <span class="kc">true</span><span class="p">,</span>                 <span class="c1">// 开启编辑器区域平滑滚动效果
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;editor.cursorSmoothCaretAnimation&#34;</span><span class="p">:</span> <span class="s2">&#34;on&#34;</span><span class="p">,</span>      <span class="c1">// 开启光标平滑移动效果
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;editor.cursorBlinking&#34;</span><span class="p">:</span> <span class="s2">&#34;smooth&#34;</span><span class="p">,</span>              <span class="c1">// 开启光标淡入淡出效果
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;editor.fontLigatures&#34;</span><span class="p">:</span> <span class="kc">false</span><span class="p">,</span>                  <span class="c1">// 关闭字体连字效果
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>
</span></span><span class="line"><span class="cl">
</span></span><span class="line"><span class="cl">    <span class="c1">// 终端设置
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;terminal.integrated.smoothScrolling&#34;</span><span class="p">:</span> <span class="kc">true</span><span class="p">,</span>                    <span class="c1">// 开启终端平滑滚动效果
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;terminal.integrated.defaultProfile.windows&#34;</span><span class="p">:</span> <span class="s2">&#34;PowerShell&#34;</span><span class="p">,</span>     <span class="c1">// 设置终端默认启动 PowerShell
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;terminal.integrated.profiles.windows&#34;</span><span class="p">:</span> <span class="p">{</span>                       <span class="c1">// 终端详细配置
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>        <span class="nt">&#34;PowerShell&#34;</span><span class="p">:</span> <span class="p">{</span>
</span></span><span class="line"><span class="cl">            <span class="nt">&#34;path&#34;</span><span class="p">:</span> <span class="s2">&#34;C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe&#34;</span>
</span></span><span class="line"><span class="cl">        <span class="p">},</span>
</span></span><span class="line"><span class="cl">        <span class="nt">&#34;Command Prompt&#34;</span><span class="p">:</span> <span class="p">{</span>
</span></span><span class="line"><span class="cl">            <span class="nt">&#34;path&#34;</span><span class="p">:</span> <span class="s2">&#34;C:\\Windows\\System32\\cmd.exe&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">            <span class="nt">&#34;args&#34;</span><span class="p">:</span> <span class="p">[],</span>
</span></span><span class="line"><span class="cl">            <span class="nt">&#34;icon&#34;</span><span class="p">:</span> <span class="s2">&#34;terminal-cmd&#34;</span>
</span></span><span class="line"><span class="cl">        <span class="p">},</span>
</span></span><span class="line"><span class="cl">        <span class="nt">&#34;Git Bash&#34;</span><span class="p">:</span> <span class="p">{</span>
</span></span><span class="line"><span class="cl">            <span class="nt">&#34;source&#34;</span><span class="p">:</span> <span class="s2">&#34;Git Bash&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">            <span class="nt">&#34;icon&#34;</span><span class="p">:</span> <span class="s2">&#34;terminal-git-bash&#34;</span>
</span></span><span class="line"><span class="cl">        <span class="p">}</span>
</span></span><span class="line"><span class="cl">    <span class="p">},</span>
</span></span><span class="line"><span class="cl">
</span></span><span class="line"><span class="cl">
</span></span><span class="line"><span class="cl">    <span class="c1">// Code Runner
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;code-runner.runInTerminal&#34;</span><span class="p">:</span> <span class="kc">true</span><span class="p">,</span>                  <span class="c1">// 在 VS Code 集成的终端中运行
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;code-runner.languageIdToFileExtensionMap&#34;</span><span class="p">:</span> <span class="p">{</span>       <span class="c1">// 扩展名映射
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>        <span class="nt">&#34;bat&#34;</span><span class="p">:</span> <span class="s2">&#34;.bat&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">        <span class="nt">&#34;powershell&#34;</span><span class="p">:</span> <span class="s2">&#34;.ps1&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">        <span class="nt">&#34;typescript&#34;</span><span class="p">:</span> <span class="s2">&#34;.ts&#34;</span>
</span></span><span class="line"><span class="cl">    <span class="p">},</span>
</span></span><span class="line"><span class="cl">    <span class="nt">&#34;code-runner.executorMap&#34;</span><span class="p">:</span> <span class="p">{</span>                        <span class="c1">// 编程语言对应的执行命令
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>        <span class="nt">&#34;javascript&#34;</span><span class="p">:</span> <span class="s2">&#34;node&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">        <span class="nt">&#34;php&#34;</span><span class="p">:</span> <span class="s2">&#34;C:\\php\\php.exe&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">        <span class="nt">&#34;python&#34;</span><span class="p">:</span> <span class="s2">&#34;python&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">        <span class="nt">&#34;perl&#34;</span><span class="p">:</span> <span class="s2">&#34;perl&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">        <span class="nt">&#34;ruby&#34;</span><span class="p">:</span> <span class="s2">&#34;C:\\Ruby23-x64\\bin\\ruby.exe&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">        <span class="nt">&#34;go&#34;</span><span class="p">:</span> <span class="s2">&#34;go run&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">        <span class="nt">&#34;html&#34;</span><span class="p">:</span> <span class="s2">&#34;\&#34;C:\\Program Files (x86)\\Google\\Chrome\\Application\\chrome.exe\&#34;&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">        <span class="nt">&#34;java&#34;</span><span class="p">:</span> <span class="s2">&#34;cd $dir &amp;&amp; javac $fileName &amp;&amp; java $fileNameWithoutExt&#34;</span><span class="p">,</span>
</span></span><span class="line"><span class="cl">        <span class="c1">// 控制台代码页切换到 UTF-8 (65001)，避免中文乱码
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>        <span class="nt">&#34;c&#34;</span><span class="p">:</span> <span class="s2">&#34;chcp 65001 &amp;&amp; cd $dir &amp;&amp; gcc $fileName -o $fileNameWithoutExt &amp;&amp; $dir$fileNameWithoutExt&#34;</span>
</span></span><span class="line"><span class="cl">    <span class="p">},</span>
</span></span><span class="line"><span class="cl">
</span></span><span class="line"><span class="cl">
</span></span><span class="line"><span class="cl">    <span class="c1">// Lingma - Alibaba Cloud AI Coding Assistant
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;Lingma.aI Chat.memories&#34;</span><span class="p">:</span> <span class="kc">false</span><span class="p">,</span>                           <span class="c1">// 关闭通义灵码记忆功能
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;Lingma.aI Chat.webToolsInAsk/AgentMode&#34;</span><span class="p">:</span> <span class="s2">&#34;Auto-execute&#34;</span><span class="p">,</span>   <span class="c1">// 允许通义灵码自动调用工具
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>
</span></span><span class="line"><span class="cl">
</span></span><span class="line"><span class="cl">    <span class="c1">// Python
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;python.autoComplete.extraPaths&#34;</span><span class="p">:</span> <span class="p">[],</span>               <span class="c1">// 为自动补全功能添加额外的模块搜索路径
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;python.analysis.completeFunctionParens&#34;</span><span class="p">:</span> <span class="kc">true</span><span class="p">,</span>     <span class="c1">// 开启自动补全括号和占位符
</span></span></span><span class="line"><span class="cl"><span class="c1"></span>    <span class="nt">&#34;python.analysis.typeCheckingMode&#34;</span><span class="p">:</span> <span class="s2">&#34;standard&#34;</span><span class="p">,</span>     <span class="c1">// 设置类型检查模式为标准
</span></span></span><span class="line"><span class="cl"><span class="c1"></span><span class="p">}</span>
</span></span></code></pre></div>]]></description>
